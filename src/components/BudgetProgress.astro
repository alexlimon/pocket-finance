---
import { formatCurrency, type BudgetProgress as BPItem } from '../lib/finance';

interface Props {
  items: BPItem[];
}

const { items } = Astro.props;
---

<div class="rounded-xl border border-surface-border bg-surface-card p-4">
  <h2 class="mb-4 text-xs font-semibold uppercase tracking-wide text-stone-400">Budget Progress</h2>

  {items.length === 0 ? (
    <p class="text-center text-sm text-stone-400 py-4">
      No budget targets configured.
      <a href="/connect" class="text-brand-green hover:underline ml-1">Set up budgets →</a>
    </p>
  ) : (
    <div class="space-y-3">
      {items.map(item => {
        const pctCapped   = Math.min(item.pct, 1);
        const barColor    = item.isOver ? 'bg-brand-red' : item.pct > 0.8 ? 'bg-brand-yellow' : 'bg-brand-green';
        const textColor   = item.isOver ? 'text-brand-red' : 'text-stone-600';
        const remaining   = item.target - item.spent;

        return (
          <div>
            <div class="flex items-baseline justify-between mb-1">
              <span class="text-sm text-stone-600">{item.name}</span>
              <span class={`text-xs tabular-nums ${textColor}`}>
                {formatCurrency(item.spent)} / {formatCurrency(item.target)}
              </span>
            </div>
            <div class="h-1.5 rounded-full bg-surface overflow-hidden">
              <div
                class={`h-full rounded-full transition-all ${barColor}`}
                style={`width: ${(pctCapped * 100).toFixed(1)}%`}
              ></div>
            </div>
            {item.isOver ? (
              <p class="mt-0.5 text-xs text-brand-red">
                {formatCurrency(Math.abs(remaining))} over budget
              </p>
            ) : (
              <p class="mt-0.5 text-xs text-stone-400">
                {formatCurrency(remaining)} remaining
              </p>
            )}
          </div>
        );
      })}
    </div>
  )}
</div>
