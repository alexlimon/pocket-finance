---
import { formatCurrency, type UpcomingBill } from '../lib/finance';

interface Props {
  amount: number;
  bills:  UpcomingBill[];
}

const { amount, bills } = Astro.props;

const isNeg    = amount < 0;
const color    = isNeg ? 'text-brand-red' : amount < 500 ? 'text-brand-yellow' : 'text-brand-green';
const billCount = bills.length;
---

<div class="col-span-2 rounded-xl border border-surface-border bg-surface-card p-4 sm:col-span-1">
  <p class="text-xs text-stone-400">Safe to Spend</p>
  <p class={`mt-1 text-3xl font-bold tabular-nums ${color}`}>
    {formatCurrency(amount)}
  </p>
  <p class="mt-2 text-xs text-stone-400">
    {billCount === 0
      ? 'No upcoming bills in the next 30 days'
      : `${billCount} bill${billCount > 1 ? 's' : ''} reserved from balance`}
  </p>
</div>
