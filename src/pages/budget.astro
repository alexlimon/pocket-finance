// ── Billing settings inline edit ─────────────────────────────────────────────
function bindSettingEdit(selector: string, field: string) {
  document.querySelectorAll<HTMLElement>(selector).forEach(el => {
    el.addEventListener('click', () => {
      const card = el.dataset.card!;
      const cur  = parseInt(el.textContent!) || 0;
      const inp  = document.createElement('input');
      inp.type='number'; inp.min='1'; inp.max='31'; inp.value=String(cur);
      inp.className='w-10 rounded border border-brand-green bg-white px-1 py-0 text-xs tabular-nums focus:outline-none';
      el.replaceWith(inp); inp.focus(); inp.select();
      async function save() {
        const v = parseInt(inp.value);
        el.textContent = isNaN(v) ? String(cur)+'th' : v+'th'+(field==='payment_day'?' of next mo':'');
        inp.replaceWith(el);
        if (!isNaN(v)) await api('/api/budget/cc-settings','POST',{card,[field]:v}).catch(()=>{});
      }
      inp.addEventListener('blur',save);
      inp.addEventListener('keydown', e => { if(e.key==='Enter')save(); if(e.key==='Escape'){inp.replaceWith(el);} });
    });
  });
}
bindSettingEdit('.billing-end-edit','billing_end_day');
bindSettingEdit('.payment-day-edit','payment_day');

// ── CC desc / amount edit ────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('.editable-cc-desc, .editable-cc-amount').forEach(el => {
