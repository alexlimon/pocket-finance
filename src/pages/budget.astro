---
import Layout from '../layouts/Layout.astro';
import { verifySession } from '../lib/auth';
import { getClient } from '../lib/db';
import { fmt, monthLabel, prevMonth, nextMonth, currentMonth, type MonthlySummary, type CCCharge, type CashExpense } from '../lib/budget';
import {
  resolveBillStatus, categorizeBills, groupBigPurchasesByPayMonth,
  computeCCPayment, computeCCSpendingTracker, computeCashFlow, computeBalances, subBillingMonth,
  type ResolvedBill, type BigPurchase,
} from '../lib/budget-calc';

const env = Astro.locals.runtime.env;
if (!(await verifySession(Astro.request, env))) return Astro.redirect('/login');

const month    = Astro.url.searchParams.get('month') ?? currentMonth();
const prev     = prevMonth(month);
const next     = nextMonth(month);
const label    = monthLabel(month);
const isNow    = month === currentMonth();
const todayDay = new Date().getDate();

const client = getClient(env);

// ── Data defaults (overwritten by DB fetch below) ────────────────────────────
let summary: MonthlySummary = {
  month, income_alex:0, income_maham:0, income_other:0,
  checking_before:0, checking_after:0, savings_before:0, savings_after:0,
  cc_budget:5000, notes:null,
};
let bills:            ResolvedBill[] = [];
let nextBills:        ResolvedBill[] = [];
let bigPurchases:     BigPurchase[]  = [];
let cashExpenses:     CashExpense[]  = [];
let ccSettings:       { card: string; display_name: string; billing_end_day: number; payment_day: number }[] = [];
let variableSpendRows:{ card: string; amount: number }[] = [];
let nextMonthCCBudget: number | null = null;

// ── Database fetches ─────────────────────────────────────────────────────────
const BILLS_SELECT = `
  SELECT bc.*,
         bp.id as payment_id,
         bp.amount as paid_amount,
         COALESCE(bp.is_paid, -1) as explicit_paid,
         COALESCE(bp.is_cc, bc.is_cc_default) as is_cc,
         COALESCE(bp.is_skipped, 0) as is_skipped
  FROM budget_config bc
  LEFT JOIN bill_payments bp ON bc.id = bp.bill_id AND bp.month = ?`;
const BILLS_QUERY    = BILLS_SELECT + ` WHERE bc.is_recurring = 1 ORDER BY bc.is_cc_default ASC, bc.due_day ASC NULLS LAST, bc.name ASC`;
const CC_BILLS_QUERY = BILLS_SELECT + ` WHERE bc.is_recurring = 1 AND bc.is_cc_default = 1 ORDER BY bc.due_day ASC NULLS LAST, bc.name ASC`;

let savedRecurringMode: 'estimated' | 'actual' | null = null;

try {
  const [sumRes, billRes, bigPurchasesRes, cashRes, settingsRes, prevSumRes, varRes, nextSumRes, nextBillRes, recurringModeRes] = await Promise.all([
    client.execute({ sql: 'SELECT * FROM monthly_summary WHERE month = ? LIMIT 1', args: [month] }),
    client.execute({ sql: BILLS_QUERY, args: [month] }),
    // cc_charges only contains big purchases (variable spend lives in cc_variable_spend)
    client.execute({
      sql: `SELECT cc.*, cs.billing_end_day, cs.payment_day
            FROM cc_charges cc
            LEFT JOIN cc_settings cs ON cc.card = cs.card
            WHERE cc.month = ? AND cc.is_big_purchase = 1
            ORDER BY cc.date ASC NULLS LAST, cc.amount DESC`,
      args: [month],
    }),
    client.execute({ sql: 'SELECT * FROM cash_expenses WHERE month = ? ORDER BY date ASC', args: [month] }),
    client.execute("SELECT * FROM cc_settings WHERE card != 'other' ORDER BY card"),
    // Previous month — propagate balances forward when this month has no DB record yet
    client.execute({ sql: 'SELECT * FROM monthly_summary WHERE month = ? LIMIT 1', args: [prev] }),
    client.execute({ sql: 'SELECT * FROM cc_variable_spend WHERE month = ? ORDER BY card', args: [month] }),
    // Next month — its cc_budget is THIS month's CC spending budget (payment-month convention)
    client.execute({ sql: 'SELECT * FROM monthly_summary WHERE month = ? LIMIT 1', args: [next] }),
    // Next month CC bills — subs charged this cycle are tracked in next month's bill_payments
    client.execute({ sql: CC_BILLS_QUERY, args: [next] }),
    // Saved est/actual toggle for this month
    client.execute({ sql: `SELECT value FROM settings WHERE key = ? LIMIT 1`, args: [`cc_recurring_mode_${month}`] }),
  ]);

  if (recurringModeRes.rows.length) {
    const v = String((recurringModeRes.rows[0] as any).value);
    if (v === 'actual' || v === 'estimated') savedRecurringMode = v;
  }

  // Resolve this month's summary, or propagate from the previous month if new
  if (sumRes.rows.length) {
    summary = sumRes.rows[0] as unknown as MonthlySummary;
  } else if (prevSumRes.rows.length) {
    const p = prevSumRes.rows[0] as unknown as MonthlySummary;
    summary = {
      ...summary,
      checking_before: Number(p.checking_after),
      checking_after:  Number(p.checking_after),
      savings_before:  Number(p.savings_after),
      savings_after:   Number(p.savings_after),
      income_alex:     Number(p.income_alex),
      income_maham:    Number(p.income_maham),
      income_other:    Number(p.income_other),
    };
  }

  if (nextSumRes.rows.length) {
    nextMonthCCBudget = Number((nextSumRes.rows[0] as any).cc_budget) || null;
  }

  ccSettings        = settingsRes.rows     as unknown as typeof ccSettings;
  bigPurchases      = bigPurchasesRes.rows as unknown as BigPurchase[];
  cashExpenses      = cashRes.rows         as unknown as CashExpense[];
  variableSpendRows = varRes.rows          as unknown as typeof variableSpendRows;
  bills             = resolveBillStatus(billRes.rows as any[], isNow, todayDay);
  nextBills         = resolveBillStatus(nextBillRes.rows as any[], isNow, todayDay, /* allowAuto */ false);
} finally { client.close(); }

// ── Derived data ─────────────────────────────────────────────────────────────
const settingsMap          = new Map(ccSettings.map(s => [s.card, s]));
const defaultBillingEndDay = settingsMap.get('sapphire')?.billing_end_day ?? 25;

const { checkingBills, ccBills } = categorizeBills(bills);
const bigPayGroups                = groupBigPurchasesByPayMonth(bigPurchases);

const ccPayment = computeCCPayment({
  ccBills,
  billingEndDay:    defaultBillingEndDay,
  paymentMonth:     month,
  ccVariableBudget: Number(summary.cc_budget),
});

const ccTracker = computeCCSpendingTracker({
  nextBills,
  billingEndDay:     defaultBillingEndDay,
  nextMonth:         next,
  variableSpendRows,
  bigPurchases,
  nextMonthCCBudget,
  currentCCBudget:   Number(summary.cc_budget),
  savedDisplayMode:  savedRecurringMode,
});

const cashFlow = computeCashFlow({
  summary,
  checkingBills,
  ccPaymentAmount: ccPayment.ccPaymentAmount,
  cashExpenses,
});

const balances = computeBalances(summary, cashFlow.netAmount);

// Destructure for template use
const { ccBillsForPayment, recurringMode: ccRecurringMode, recurringBudget: ccRecurringBudget, ccPaymentAmount } = ccPayment;
const { ccBillsNextPayment, estimatedCCRecurring, actualCCRecurring, ccDisplayMode, ccRecurringInVariable,
        variableSpendMap, ccVariableTotal, ccVariableOnly, ccBig, ccUsed, ccSpendBudget, ccRemaining, ccUsedPct } = ccTracker;
const { otherCashIncomes, otherCashExpenses, otherCashIncomeTotal, otherCashExpenseTotal, totalFixedChecking, incomeTotal, netAmount } = cashFlow;
const { checkingStart, checkingEnd, savingsStart, savingsEnd, savingsAllocation } = balances;
---

<Layout title={label}>
<!-- ── Month nav ── -->
<div class="mb-5 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href={`/budget?month=${prev}`} class="rounded-lg border border-surface-border px-3 py-1.5 text-sm text-stone-500 hover:text-stone-800">←</a>
    <h1 class="text-xl font-semibold text-stone-800">{label}</h1>
    <a href={`/budget?month=${next}`} class="rounded-lg border border-surface-border px-3 py-1.5 text-sm text-stone-500 hover:text-stone-800">→</a>
    {isNow && <span class="rounded-full bg-lime-50 px-2 py-0.5 text-xs text-brand-green border border-lime-200">Current</span>}
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- ── Monthly Cash Flow (NET) — the main feature, always on top ── -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="mb-5 rounded-xl border-2 border-lime-300 bg-surface-card p-5">
  <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-stone-600">Monthly Cash Flow</h2>
  <div class="space-y-2 text-sm">
    <!-- Income -->
    <div class="flex items-center justify-between">
      <span class="text-stone-500">Total Income</span>
      <span class="tabular-nums font-medium text-brand-green">{fmt(incomeTotal + otherCashIncomeTotal)}</span>
    </div>
    <div class="pl-4 space-y-1 text-xs text-stone-400">
      <div class="flex justify-between"><span>Alex + Maham salaries</span><span class="tabular-nums">{fmt(Number(summary.income_alex) + Number(summary.income_maham))}</span></div>
      {otherCashIncomes.map(e => (
        <div class="flex justify-between"><span>{e.description}</span><span class="tabular-nums">{fmt(e.amount)}</span></div>
      ))}
    </div>

    <!-- Fixed Bills (checking) -->
    <div class="flex items-center justify-between pt-1">
      <span class="text-stone-500">Fixed Bills (checking)</span>
      <span class="tabular-nums font-medium text-brand-red">-{fmt(totalFixedChecking)}</span>
    </div>

    <!-- CC Payment -->
    <div class="flex items-center justify-between">
      <span class="text-stone-500">CC Payment</span>
      <span class="tabular-nums font-medium text-brand-red" id="cf-cc-payment">-{fmt(ccPaymentAmount)}</span>
    </div>
    <div class="pl-4 space-y-1 text-xs text-stone-400">
      <div class="flex justify-between"><span>Variable + Big</span><span class="tabular-nums cursor-pointer rounded px-1 hover:bg-surface-hover" data-field="cc_budget" data-month={month} title="Click to edit">{fmt(Number(summary.cc_budget))}</span></div>
      <div class="flex justify-between"><span>Recurring <span class="text-stone-300">({ccRecurringMode === 'estimated' ? 'est' : 'act'})</span></span><span class="tabular-nums" id="cf-cc-recurring">{fmt(ccRecurringBudget)}</span></div>
    </div>

    <!-- Other Cash Expenses -->
    {otherCashExpenseTotal > 0 && (
      <div class="flex items-center justify-between">
        <span class="text-stone-500">Other Cash Expenses</span>
        <span class="tabular-nums font-medium text-brand-red">-{fmt(otherCashExpenseTotal)}</span>
      </div>
    )}
    {otherCashExpenses.length > 0 && (
      <div class="pl-4 space-y-1 text-xs text-stone-400">
        {otherCashExpenses.map(e => (
          <div class="flex justify-between"><span>{e.description}</span><span class="tabular-nums">{fmt(e.amount)}</span></div>
        ))}
      </div>
    )}

    <!-- NET -->
    <div class="flex items-center justify-between border-t-2 border-surface-border pt-3 mt-2">
      <span class="text-stone-800 font-semibold text-base">NET</span>
      <span class={`tabular-nums text-xl font-bold ${netAmount >= 0 ? 'text-brand-green' : 'text-brand-red'}`} id="cf-net" data-net-amount={netAmount}>{fmt(netAmount)}</span>
    </div>

    <!-- Where the money goes -->
    <div class="pt-3 mt-2 border-t border-surface-border space-y-3">
      <!-- Savings -->
      <div class="rounded-lg border border-surface-border bg-surface p-3">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold uppercase tracking-wide text-stone-400">Savings</span>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-stone-500">Start</span>
          <span class="editable-field tabular-nums cursor-pointer rounded px-2 py-0.5 hover:bg-surface-hover text-stone-600 text-xs"
            data-field="savings_before" data-month={month} data-endpoint="/api/budget/summary">{fmt(savingsStart)}</span>
        </div>
        <div class="flex items-center justify-between text-sm mt-1">
          <span class="text-stone-500">Transfer to savings</span>
          <span class="savings-allocation-edit tabular-nums cursor-pointer rounded px-2 py-0.5 hover:bg-surface-hover text-stone-800 font-medium"
            data-month={month} data-savings-start={savingsStart}>{fmt(savingsAllocation)}</span>
        </div>
        <div class="flex items-center justify-between text-sm mt-1 pt-1 border-t border-surface-border">
          <span class="text-stone-600 font-medium">End</span>
          <span class="tabular-nums font-semibold text-stone-800" id="savings-end-val">{fmt(savingsEnd)}</span>
        </div>
      </div>

      <!-- Checking -->
      <div class="rounded-lg border border-surface-border bg-surface p-3">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold uppercase tracking-wide text-stone-400">Checking</span>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-stone-500">Start</span>
          <span class="editable-field tabular-nums cursor-pointer rounded px-2 py-0.5 hover:bg-surface-hover text-stone-600 text-xs"
            data-field="checking_before" data-month={month} data-endpoint="/api/budget/summary">{fmt(checkingStart)}</span>
        </div>
        <div class="flex items-center justify-between text-sm mt-1 text-xs text-stone-400">
          <span>+ NET</span>
          <span class={`tabular-nums ${netAmount >= 0 ? 'text-brand-green' : 'text-brand-red'}`} id="cf-checking-net">{fmt(netAmount)}</span>
        </div>
        <div class="flex items-center justify-between text-sm mt-1 text-xs text-stone-400">
          <span>- To savings</span>
          <span class="tabular-nums" id="checking-savings-deduct">-{fmt(savingsAllocation)}</span>
        </div>
        <div class="flex items-center justify-between text-sm mt-1 pt-1 border-t border-surface-border">
          <span class="text-stone-600 font-medium">End</span>
          <span class={`tabular-nums font-semibold ${checkingEnd >= 0 ? 'text-stone-800' : 'text-brand-red'}`} id="checking-end-val">{fmt(checkingEnd)}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- ── Income + Fixed Bills — side by side ── -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="mb-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
  <!-- Income -->
  <div class="rounded-xl border border-surface-border bg-surface-card p-4">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide text-stone-400">Income</h2>
    <div class="space-y-2 text-sm">
      {[
        ['income_alex',  'Alex',  summary.income_alex],
        ['income_maham', 'Maham', summary.income_maham],
      ].map(([field, lbl, val]) => (
        <div class="flex items-center justify-between">
          <span class="text-stone-500">{lbl}</span>
          <span class="editable-field tabular-nums cursor-pointer rounded px-2 py-0.5 hover:bg-surface-hover text-stone-800"
            data-field={field} data-month={month} data-endpoint="/api/budget/summary">{fmt(Number(val))}</span>
        </div>
      ))}
      {otherCashIncomes.length > 0 && otherCashIncomes.map(e => (
        <div class="flex items-center justify-between">
          <span class="text-stone-500">{e.description}</span>
          <span class="tabular-nums text-brand-green">{fmt(e.amount)}</span>
        </div>
      ))}
      <div class="flex justify-between border-t border-surface-border pt-2 mt-1">
        <span class="text-stone-400 text-xs">Total</span>
        <span class="text-brand-green font-semibold tabular-nums">{fmt(incomeTotal + otherCashIncomeTotal)}</span>
      </div>
    </div>
  </div>

  <!-- Fixed bills (checking) -->
  <div class="rounded-xl border border-surface-border bg-surface-card p-4">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide text-stone-400">Fixed Bills — Checking</h2>
    <div class="space-y-1" id="checking-bills">
      {checkingBills.map(b => (
        <div class="flex items-center justify-between gap-2 rounded-lg px-2 py-1.5 hover:bg-surface-hover group" data-bill-id={b.id}>
          <div class="flex items-center gap-2 min-w-0">
            <input type="checkbox" checked={b.effective_paid}
              class="bill-toggle h-4 w-4 rounded border-stone-300 bg-surface accent-emerald-500 cursor-pointer"
              data-bill={b.id} data-month={month} data-is-cc="0" data-is-auto={b.is_auto ? '1' : '0'}
            />
            <span class={`text-sm truncate ${b.effective_paid ? 'text-stone-600' : 'text-stone-400'}`}>{b.name}</span>
            {b.due_day && <span class="text-xs text-stone-400 flex-shrink-0">{b.due_day}th</span>}
            {b.is_auto && <span class="text-xs text-stone-400 italic">auto</span>}
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            <span class={`editable-bill-amount tabular-nums text-sm cursor-pointer rounded px-1.5 py-0.5 hover:bg-surface-hover ${b.effective_paid ? 'text-stone-700' : 'text-stone-400'}`}
              data-bill={b.id} data-month={month} data-is-cc="0">{fmt(b.actual_amount)}</span>
            <button class="skip-bill opacity-0 group-hover:opacity-100 text-stone-300 hover:text-brand-red text-xs px-1 transition-opacity"
              data-bill={b.id} data-month={month} title="Skip this month">✕</button>
          </div>
        </div>
      ))}
    </div>
    <!-- CC Payment line -->
    <div class="mt-2 border-t border-surface-border pt-2">
      <div class="flex items-center justify-between gap-2 rounded-lg px-2 py-1.5 hover:bg-surface-hover">
        <div class="min-w-0">
          <span class="text-sm text-stone-600">Credit Card Payment</span>
        </div>
        <span class="tabular-nums text-sm text-stone-700 flex-shrink-0" id="fb-cc-payment">{fmt(ccPaymentAmount)}</span>
      </div>
    </div>
    <div class="mt-2 border-t border-surface-border pt-2 flex justify-between text-xs">
      <span class="text-stone-400">Total from checking</span>
      <span class="tabular-nums text-stone-500" id="fb-total-checking">{fmt(totalFixedChecking + ccPaymentAmount)}</span>
    </div>
  </div>
</div>

<!-- ── Other Cash (income + expenses) ── -->
<div class="mb-4 rounded-xl border border-surface-border bg-surface-card p-4">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-stone-400">Other Cash</h2>
    <span class="text-xs text-stone-400">Add income (rent, bonuses) or one-off expenses</span>
  </div>
  <div id="cash-expenses-list" class="space-y-1 mb-3">
    {cashExpenses.length === 0 && <p class="text-xs text-stone-400 py-1">No other cash items this month.</p>}
    {cashExpenses.map(e => (
      <div class="flex items-center gap-2 text-sm group rounded-lg px-2 py-1.5 hover:bg-surface-hover" data-cash-id={e.id}>
        <span class={`rounded px-1.5 py-0.5 text-xs flex-shrink-0 border ${(e as any).type==='income' ? 'border-lime-300 text-brand-green bg-lime-50' : 'border-surface-border text-stone-400'}`}>
          {(e as any).type === 'income' ? 'income' : 'expense'}
        </span>
        <span class="text-stone-400 text-xs w-20 flex-shrink-0">{e.date ?? '—'}</span>
        <span class="flex-1 text-stone-700 truncate">{e.description}</span>
        {e.entity_id !== 'household' && (
          <span class="rounded border border-surface-border px-1.5 py-0.5 text-xs capitalize text-stone-400 flex-shrink-0">{e.entity_id}</span>
        )}
        <span class={`tabular-nums flex-shrink-0 font-medium ${(e as any).type==='income' ? 'text-brand-green' : 'text-stone-700'}`}>
          {(e as any).type === 'income' ? '+' : ''}{fmt(e.amount)}
        </span>
        <button class="delete-cash opacity-0 group-hover:opacity-100 text-stone-400 hover:text-brand-red text-xs px-1" data-id={e.id}>✕</button>
      </div>
    ))}
  </div>
  <form class="add-cash-form flex flex-wrap gap-2" data-month={month}>
    <select name="type" class="rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-xs text-stone-600 focus:border-brand-green focus:outline-none flex-shrink-0">
      <option value="expense">Expense</option>
      <option value="income">Income</option>
    </select>
    <input name="date" type="date" value={`${month}-${String(todayDay).padStart(2,'0')}`} class="w-32 rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-xs text-stone-600 focus:border-brand-green focus:outline-none flex-shrink-0" />
    <input name="description" placeholder="Description" required
      class="flex-1 rounded-lg border border-surface-border bg-surface px-3 py-1.5 text-sm text-stone-800 placeholder-stone-400 focus:border-brand-green focus:outline-none min-w-0" />
    <select name="entity_id" class="rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-xs text-stone-600 focus:outline-none flex-shrink-0">
      <option value="household">Household</option>
      <option value="kirby">Kirby</option>
      <option value="kennedy">Kennedy</option>
    </select>
    <input name="amount" type="number" step="0.01" placeholder="0.00" required
      class="w-24 rounded-lg border border-surface-border bg-surface px-3 py-1.5 text-sm text-stone-800 tabular-nums focus:border-brand-green focus:outline-none flex-shrink-0" />
    <button type="submit" class="rounded-lg bg-surface-hover border border-surface-border px-3 py-1.5 text-xs text-stone-600 hover:text-stone-800 flex-shrink-0">+ Add</button>
  </form>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- ── Credit Card Section — all CC-related items together ── -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->

<!-- CC Variable Spend (one row per card) -->
<div class="mb-4 rounded-xl border border-surface-border bg-surface-card p-4">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-stone-400">CC Variable Spend</h2>
    <a href="/connect" class="text-xs text-stone-400 hover:text-stone-500">Edit billing dates</a>
  </div>

  <div class="space-y-2" id="variable-spend-rows">
    {ccSettings.map(s => {
      const amount = variableSpendMap.get(s.card) ?? 0;
      const [yr, mo] = month.split('-').map(Number);
      const payD = new Date(yr, mo, 1);
      const payLabel = `${payD.toLocaleString('en-US',{month:'long',year:'numeric'})} (due ${s.payment_day}th)`;

      return (
        <div class="flex items-center gap-4 rounded-lg border border-surface-border px-4 py-3 hover:bg-surface-hover">
          <span class="text-sm font-medium text-stone-600 w-36 flex-shrink-0">{s.display_name}</span>
          <span
            class="var-spend-amount tabular-nums text-xl font-semibold cursor-pointer rounded px-2 py-0.5 hover:bg-surface-hover text-stone-800"
            data-card={s.card} data-month={month}
          >{fmt(amount)}</span>
          <span class="text-xs text-stone-400 flex-1">paying {payLabel}</span>
          <span class="text-xs text-stone-400">closes {s.billing_end_day}th</span>
        </div>
      );
    })}
  </div>

  <div class="mt-3 flex justify-between border-t border-surface-border pt-2">
    <span class="text-xs text-stone-400">Total variable CC</span>
    <span class="tabular-nums text-sm font-medium text-stone-600" id="cc-variable-val">{fmt(ccVariableTotal)}</span>
  </div>
</div>

<!-- CC Budget Bar -->
<div class="mb-4 rounded-xl border border-surface-border bg-surface-card p-4">
  <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
    <div>
      <h2 class="text-xs font-semibold uppercase tracking-wide text-stone-400 mb-1">Credit Card Spending Budget</h2>
      <div class="flex items-baseline gap-2 flex-wrap">
        <span id="cc-remaining-val"
          class={`text-2xl font-bold tabular-nums ${ccRemaining < 0 ? 'text-brand-red' : ccRemaining < 500 ? 'text-brand-yellow' : 'text-brand-green'}`}>
          {fmt(ccRemaining)}
        </span>
        <span class="text-xs text-stone-400">remaining of</span>
        <span class="tabular-nums text-stone-600 text-sm cursor-pointer rounded px-1 hover:bg-surface-hover"
          id="cc-budget-display" data-recurring={ccRecurringInVariable}
          data-field="cc_budget" data-month={next}
          title="Click to edit spending budget">{fmt(ccSpendBudget)}</span>
      </div>
    </div>
    <div class="flex gap-4 text-right text-sm">
      <div><p class="text-xs text-stone-400">Variable</p><p class="tabular-nums text-stone-600" id="cc-variable-val2">{fmt(ccVariableOnly)}</p></div>
      <div><p class="text-xs text-stone-400">Big Purchases</p><p class="tabular-nums text-stone-500" id="cc-big-val">{fmt(ccBig)}</p></div>
      <div><p class="text-xs text-stone-400">Total Charged</p><p class="tabular-nums font-medium text-stone-700" id="cc-total-val">{fmt(ccUsed)}</p></div>
    </div>
  </div>
  <div class="h-2 rounded-full bg-surface overflow-hidden">
    <div id="cc-bar" class={`h-full rounded-full transition-all ${ccUsedPct>=100?'bg-brand-red':ccUsedPct>=80?'bg-brand-yellow':'bg-brand-green'}`}
      style={`width:${ccUsedPct.toFixed(1)}%`}></div>
  </div>
  <p class="mt-1 text-xs text-stone-400">Variable spend + big purchases count against budget. Recurring subscriptions are separate.</p>
</div>

<!-- CC Recurring Subscriptions -->
<div class="mb-4 rounded-xl border border-surface-border bg-surface-card p-4"
  id="cc-recurring-section"
  data-estimated={estimatedCCRecurring}
  data-actual={actualCCRecurring}
  data-payment-recurring={ccRecurringBudget}
  data-cc-variable-budget={Number(summary.cc_budget)}
  data-fixed-checking={totalFixedChecking}
  data-other-cash-expense={otherCashExpenseTotal}
  data-income-total={incomeTotal + otherCashIncomeTotal}
  data-checking-start={checkingStart}
  data-savings-allocation={savingsAllocation}
  data-mode={ccDisplayMode}
>
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-stone-400">CC Recurring Subscriptions</h2>
    <div class="flex items-center gap-3 text-xs">
      <button id="recurring-mode-toggle"
        class="flex items-center gap-1.5 rounded-full border border-surface-border px-2.5 py-1 text-xs hover:bg-surface-hover transition-colors"
        title="Toggle between estimated and actual recurring amounts"
      >
        <span id="mode-label-est" class={ccDisplayMode === 'estimated' ? 'font-semibold text-stone-700' : 'text-stone-400'}>{fmt(estimatedCCRecurring)}</span>
        <span class="text-stone-300">/</span>
        <span id="mode-label-act" class={ccDisplayMode === 'actual' ? 'font-semibold text-stone-700' : 'text-stone-400'}>{fmt(actualCCRecurring)}</span>
      </button>
      <span class="text-stone-300 text-xs recurring-mode-label">{ccDisplayMode === 'estimated' ? 'est' : 'act'}</span>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-1" id="cc-bills">
    {ccBillsNextPayment.map(b => {
      const bm = subBillingMonth(b, defaultBillingEndDay, month);
      const billingLabel = bm ? `${new Date(bm+'-01').toLocaleString('en-US',{month:'short'})}` : '';
      return (
        <div class="group flex items-center justify-between gap-1 rounded px-1 py-1 hover:bg-surface-hover" data-bill-id={b.id}>
          <div class="flex items-center gap-1.5 min-w-0">
            <input type="checkbox" checked={b.effective_paid}
              class="bill-toggle h-3.5 w-3.5 rounded border-stone-300 bg-surface accent-emerald-500 cursor-pointer"
              data-bill={b.id} data-month={next} data-is-cc="1" data-is-auto={b.is_auto ? '1' : '0'}
            />
            <span class={`text-xs truncate ${b.effective_paid ? 'text-stone-600' : 'text-stone-400'}`}>{b.name}</span>
            {(billingLabel || b.due_day) && (
              <span class="text-xs text-stone-300 flex-shrink-0" title="Billing month · due day">
                {billingLabel}{b.due_day ? ` ${b.due_day}` : ''}
              </span>
            )}
            {b.is_auto && <span class="text-xs text-stone-400">*</span>}
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            <span class={`editable-bill-amount tabular-nums text-xs cursor-pointer rounded px-1 py-0.5 hover:bg-surface-hover ${b.effective_paid ? 'text-stone-700' : 'text-stone-400'}`}
              data-bill={b.id} data-month={next} data-is-cc="1">{fmt(b.actual_amount)}</span>
            <button class="cc-sub-skip opacity-0 group-hover:opacity-100 text-stone-300 hover:text-brand-red text-xs px-0.5 leading-none"
              data-bill-id={b.id} data-month={next} title="Skip this sub for this month">✕</button>
          </div>
        </div>
      );
    })}
  </div>

  <p class="mt-2 text-xs text-stone-400">
    Month label = billing month (when the charge hit the CC). Items auto-filtered to this payment cycle only. * = auto-checked (today &gt;= due date). These are included in the CC Payment amount in Fixed Bills above but do not count against the CC spending budget.
  </p>
</div>

<!-- Big Purchases -->
<div class="mb-4 rounded-xl border border-surface-border bg-surface-card p-4">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-stone-400">Big Purchases</h2>
    <span class="text-xs text-stone-400">Count against CC budget</span>
  </div>

  <div id="big-cc-charges" class="space-y-3 mb-4">
    {bigPayGroups.length === 0 && (
      <p class="text-xs text-stone-400 py-2">No big purchases this month.</p>
    )}
    {bigPayGroups.map(([payMonth, charges]) => {
      const d = new Date(payMonth + '-01');
      const moName = payMonth === 'unknown' ? 'No Date Set'
        : `Paying in ${d.toLocaleString('en-US',{month:'long',year:'numeric'})} (due ${ccSettings[0]?.payment_day??15}th)`;
      const groupTotal = charges.reduce((s,c)=>s+c.amount,0);
      return (
        <div class="rounded-lg border border-surface-border overflow-hidden" data-big-pay-month={payMonth}>
          <div class="flex items-center justify-between bg-surface px-3 py-2">
            <span class={`text-xs font-semibold ${payMonth==='unknown'?'text-stone-400':'text-stone-600'}`}>{moName}</span>
            <span class="big-group-total tabular-nums text-xs font-medium text-stone-600">{fmt(groupTotal)}</span>
          </div>
          <div class="big-charges-body divide-y divide-surface-border">
            {charges.map(c => (
              <div class="flex items-center gap-2 px-3 py-2 hover:bg-surface-hover group text-sm" data-cc-id={c.id}>
                <span class="text-stone-400 text-xs w-20 flex-shrink-0 tabular-nums">{c.date??'—'}</span>
                <select class="cc-card-select rounded border border-surface-border bg-surface px-1.5 py-0.5 text-xs text-stone-500 flex-shrink-0" data-id={c.id}>
                  {ccSettings.map(s=><option value={s.card} selected={c.card===s.card}>{s.display_name}</option>)}
                </select>
                <span class="editable-cc-desc flex-1 cursor-pointer rounded px-1 hover:bg-surface-hover text-stone-700 truncate" data-id={c.id}>{c.description}</span>
                <span class="editable-cc-amount tabular-nums cursor-pointer rounded px-1.5 hover:bg-surface-hover text-stone-700 flex-shrink-0" data-id={c.id}>{fmt(c.amount)}</span>
                <button class="cc-toggle-big opacity-0 group-hover:opacity-100 text-xs px-1 text-stone-400 hover:text-stone-600" data-id={c.id} data-big="1" title="Move to Variable">↑</button>
                <button class="delete-cc-charge opacity-0 group-hover:opacity-100 text-stone-400 hover:text-brand-red text-xs px-1" data-id={c.id}>✕</button>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <form id="add-big-form" class="flex flex-wrap gap-2 items-end" data-month={month} data-big="1">
    <div class="flex flex-col gap-1">
      <label class="text-xs text-stone-400">Date</label>
      <input name="date" type="date" required class="rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-xs text-stone-600 focus:border-brand-green focus:outline-none w-36" />
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-stone-400">Card</label>
      <select name="card" class="rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-xs text-stone-600 focus:border-brand-green focus:outline-none">
        {ccSettings.map(s=><option value={s.card}>{s.display_name}</option>)}
      </select>
    </div>
    <div class="flex flex-col gap-1 flex-1 min-w-36">
      <label class="text-xs text-stone-400">Description</label>
      <input name="description" placeholder="e.g. TV, MacBook, Car repair" required class="rounded-lg border border-surface-border bg-surface px-3 py-1.5 text-sm text-stone-800 placeholder-stone-400 focus:border-brand-green focus:outline-none" />
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-stone-400">Amount</label>
      <input name="amount" type="number" step="0.01" placeholder="0.00" required class="w-24 rounded-lg border border-surface-border bg-surface px-2 py-1.5 text-sm text-stone-800 tabular-nums focus:border-brand-green focus:outline-none" />
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-stone-400 invisible">x</label>
      <button type="submit" class="rounded-lg bg-surface-hover border border-surface-border px-4 py-1.5 text-sm text-stone-600 hover:text-stone-800">+ Add Big Purchase</button>
    </div>
  </form>
</div>
</Layout>

<script>
const MONTH = new URLSearchParams(location.search).get('month') ??
  (() => { const d = new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`; })();

function usd(n: number) {
  return new Intl.NumberFormat('en-US',{style:'currency',currency:'USD',minimumFractionDigits:2}).format(n);
}
async function api(url: string, method: string, body: object) {
  const r = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (!r.ok) { const e = await r.json().catch(()=>({})) as {error?:string}; throw new Error(e.error??'Error'); }
  return r.json();
}

// ── Recompute CC remaining from DOM ──────────────────────────────────────────
// Formula: remaining = budget - (variable - recurring) - big purchases
function recomputeCC() {
  const budgetEl = document.getElementById('cc-budget-display') as HTMLElement;
  const budget    = parseFloat(budgetEl?.textContent?.replace(/[$,]/g,'') ?? '5000');
  const recurring = parseFloat(budgetEl?.dataset.recurring ?? '0');

  let variableCC = 0;
  document.querySelectorAll<HTMLElement>('.var-spend-amount').forEach(el => {
    variableCC += parseFloat(el.textContent!.replace(/[$,]/g,'')) || 0;
  });
  const variableOnly = Math.max(0, variableCC - recurring);

  let bigCC = 0;
  document.querySelectorAll('#big-cc-charges [data-cc-id]').forEach(row => {
    bigCC += parseFloat(row.querySelector('.editable-cc-amount')?.textContent?.replace(/[$,]/g,'') ?? '0');
  });

  const total     = variableOnly + bigCC;
  const remaining = budget - total;
  const pct       = Math.min(total / budget * 100, 100);

  const remEl = document.getElementById('cc-remaining-val');
  if (remEl) {
    remEl.textContent = usd(remaining);
    remEl.className = remEl.className.replace(/text-brand-\w+/g,'') + (remaining < 0 ? ' text-brand-red' : remaining < 500 ? ' text-brand-yellow' : ' text-brand-green');
  }
  const varEl = document.getElementById('cc-variable-val'); if (varEl) varEl.textContent = usd(variableOnly);
  const varEl2 = document.getElementById('cc-variable-val2'); if (varEl2) varEl2.textContent = usd(variableOnly);
  const bigEl = document.getElementById('cc-big-val');       if (bigEl) bigEl.textContent = usd(bigCC);
  const totEl = document.getElementById('cc-total-val');     if (totEl) totEl.textContent = usd(total);
  const bar   = document.getElementById('cc-bar') as HTMLElement;
  if (bar) { bar.style.width = pct.toFixed(1)+'%'; bar.className = bar.className.replace(/bg-brand-\w+/g,'')+(pct>=100?' bg-brand-red':pct>=80?' bg-brand-yellow':' bg-brand-green'); }
}

// ── Estimated / Actual recurring toggle ──────────────────────────────────────
// Swaps the recurring component of CC Payment and cascades to NET + Checking End.
function recalcCashFlow(recurringVal: number) {
  const sec  = document.getElementById('cc-recurring-section') as HTMLElement;
  const ccVarBudget      = parseFloat(sec.dataset.ccVariableBudget ?? '0');
  const fixedChecking    = parseFloat(sec.dataset.fixedChecking ?? '0');
  const otherCashExpense = parseFloat(sec.dataset.otherCashExpense ?? '0');
  const incomeTotal      = parseFloat(sec.dataset.incomeTotal ?? '0');
  const checkStart       = parseFloat(sec.dataset.checkingStart ?? '0');
  const savingsAlloc     = parseFloat(sec.dataset.savingsAllocation ?? '0');

  const ccPayment  = ccVarBudget + recurringVal;
  const net        = incomeTotal - fixedChecking - ccPayment - otherCashExpense;
  const checkEnd   = checkStart + net - savingsAlloc;

  // Update all affected elements
  const u = (id: string, v: number, prefix = '') => {
    const el = document.getElementById(id);
    if (el) el.textContent = prefix + usd(v);
  };
  u('cf-cc-payment',    ccPayment, '-');
  u('cf-cc-recurring',  recurringVal);
  u('cf-net',           net);
  u('cf-checking-net',  net);
  u('checking-end-val', checkEnd);
  u('fb-cc-payment',    ccPayment);
  u('fb-total-checking', fixedChecking + ccPayment);

  // Colour NET
  const netEl = document.getElementById('cf-net');
  if (netEl) {
    netEl.className = netEl.className.replace(/text-brand-\w+/g, '') + (net >= 0 ? ' text-brand-green' : ' text-brand-red');
    netEl.dataset.netAmount = String(net);
  }
  const netEl2 = document.getElementById('cf-checking-net');
  if (netEl2) netEl2.className = netEl2.className.replace(/text-brand-\w+/g, '') + (net >= 0 ? ' text-brand-green' : ' text-brand-red');
  const checkEndEl = document.getElementById('checking-end-val');
  if (checkEndEl) checkEndEl.className = checkEndEl.className.replace(/text-brand-red|text-stone-800/g, '') + (checkEnd >= 0 ? ' text-stone-800' : ' text-brand-red');
  
  // Save checking_after to database
  api('/api/budget/summary', 'POST', { month: MONTH, checking_after: checkEnd }).catch(() => {});
}



document.getElementById('recurring-mode-toggle')?.addEventListener('click', () => {
  const sec  = document.getElementById('cc-recurring-section') as HTMLElement;
  const mode = sec.dataset.mode === 'estimated' ? 'actual' : 'estimated';
  sec.dataset.mode = mode;
  const estVal = parseFloat(sec.dataset.estimated ?? '0');
  const actVal = parseFloat(sec.dataset.actual ?? '0');
  const val    = mode === 'estimated' ? estVal : actVal;

  // Highlight active label in the toggle button itself
  const estLabel = document.getElementById('mode-label-est');
  const actLabel = document.getElementById('mode-label-act');
  if (estLabel) estLabel.className = mode === 'estimated' ? 'font-semibold text-stone-700' : 'text-stone-400';
  if (actLabel) actLabel.className = mode === 'actual'    ? 'font-semibold text-stone-700' : 'text-stone-400';

  // Update the section's own est/act badge (scoped — not page-wide)
  sec.querySelectorAll('.recurring-mode-label').forEach(el => {
    el.textContent = mode === 'estimated' ? 'est' : 'act';
  });

  // This toggle reflects THIS billing cycle's recurring (paid next month), which
  // is the amount netted out of the CC spending-budget bar. Update the bar only.
  // CC Payment (= last cycle's recurring, paid this month) is unaffected.
  const budgetEl = document.getElementById('cc-budget-display') as HTMLElement | null;
  if (budgetEl) {
    budgetEl.dataset.recurring = String(val);
    recomputeCC();
  }

  // Persist the chosen mode so it survives page reload
  api('/api/budget/setting', 'POST', { key: `cc_recurring_mode_${MONTH}`, value: mode }).catch(() => {});
});

// ── CC recurring sub skip ─────────────────────────────────────────────────────
document.getElementById('cc-bills')?.addEventListener('click', async e => {
  const btn = (e.target as HTMLElement).closest<HTMLElement>('.cc-sub-skip');
  if (!btn) return;
  const billId   = btn.dataset.billId!;
  const billMonth = btn.dataset.month!;
  const row      = btn.closest<HTMLElement>('[data-bill-id]');
  if (!row) return;

  try {
    await api('/api/budget/bill-skip', 'POST', { month: billMonth, bill_id: billId, skip: true });
    row.remove();

    // Recompute estimated/actual totals from remaining rows
    const sec = document.getElementById('cc-recurring-section') as HTMLElement;
    let newEst = 0; let newAct = 0;
    document.querySelectorAll<HTMLElement>('#cc-bills [data-bill-id]').forEach(r => {
      const amtEl = r.querySelector<HTMLElement>('.editable-bill-amount');
      const amt   = parseFloat(amtEl?.textContent?.replace(/[$,]/g,'') ?? '0');
      const chk   = r.querySelector<HTMLInputElement>('.bill-toggle');
      // estimated uses monthly_target — we only have actual_amount in the DOM, use it as proxy
      newEst += amt;
      if (chk?.checked) newAct += amt;
    });
    sec.dataset.estimated = String(newEst);
    sec.dataset.actual    = String(newAct);

    const mode    = sec.dataset.mode as 'estimated' | 'actual';
    const recurVal = mode === 'actual' ? newAct : newEst;
    sec.dataset.paymentRecurring = String(recurVal);

    // Update toggle labels
    const estLabel = document.getElementById('mode-label-est');
    const actLabel = document.getElementById('mode-label-act');
    if (estLabel) estLabel.textContent = usd(newEst);
    if (actLabel) actLabel.textContent = usd(newAct);

    // Cascade to cash flow
    recalcCashFlow(recurVal);
  } catch (err) {
    alert('Could not skip subscription.');
  }
});

// ── CC budget click-to-edit ───────────────────────────────────────────────────
// Both the spending-budget display and the Variable+Big sub-line use data-field="cc_budget".
// The spending budget saves to next month; Variable+Big saves to current month.
document.querySelectorAll<HTMLElement>('[data-field="cc_budget"]').forEach(el => {
  el.addEventListener('click', () => {
    const fieldMonth = el.dataset.month!;
    const cur = parseFloat(el.textContent!.replace(/[$,]/g,'')) || 0;
    const inp = document.createElement('input');
    inp.type='number'; inp.step='0.01'; inp.value=String(cur);
    inp.className='w-28 rounded border border-brand-green bg-surface px-2 py-0.5 text-sm tabular-nums focus:outline-none';
    el.replaceWith(inp); inp.focus(); inp.select();
    async function save() {
      const v = parseFloat(inp.value);
      el.textContent = isNaN(v) ? usd(cur) : usd(v);
      inp.replaceWith(el);
      if (!isNaN(v) && v !== cur) {
        await api('/api/budget/summary','POST',{month:fieldMonth,cc_budget:v}).catch(()=>{});
        // If this is the spending budget (next month), update the bar too
        if (el.id === 'cc-budget-display') {
          el.dataset.recurring = el.dataset.recurring ?? '0';
          recomputeCC();
        }
        // If this is the Variable+Big line, recalc cash flow
        const sec = document.getElementById('cc-recurring-section') as HTMLElement;
        if (sec) {
          sec.dataset.ccVariableBudget = String(isNaN(v) ? cur : v);
          // CC Payment's recurring = last billing cycle (paid this month), independent of the display toggle.
          const paymentRecurring = parseFloat(sec.dataset.paymentRecurring ?? '0');
          recalcCashFlow(paymentRecurring);
        }
      }
    }
    inp.addEventListener('blur', save);
    inp.addEventListener('keydown', e => { if(e.key==='Enter') save(); if(e.key==='Escape'){el.textContent=usd(cur);inp.replaceWith(el);} });
  });
});

// ── Variable spend click-to-edit (one amount per card) ───────────────────────
document.querySelectorAll<HTMLElement>('.var-spend-amount').forEach(el => {
  el.addEventListener('click', () => {
    const card  = el.dataset.card!;
    const month = el.dataset.month!;
    const cur   = parseFloat(el.textContent!.replace(/[$,]/g,'')) || 0;
    const inp   = document.createElement('input');
    inp.type='number'; inp.step='0.01'; inp.value=String(cur);
    inp.className='w-32 rounded border border-brand-green bg-white px-2 py-0.5 text-xl font-semibold tabular-nums focus:outline-none';
    el.replaceWith(inp); inp.focus(); inp.select();
    async function save() {
      const v = parseFloat(inp.value);
      el.textContent = isNaN(v) ? usd(cur) : usd(v);
      inp.replaceWith(el);
      if (!isNaN(v)) {
        await fetch('/api/budget/cc-variable', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({month, card, amount: v}),
        }).catch(()=>{});
        recomputeCC();
        
      }
    }
    inp.addEventListener('blur', save);
    inp.addEventListener('keydown', e => { if(e.key==='Enter') save(); if(e.key==='Escape'){el.textContent=usd(cur);inp.replaceWith(el);} });
  });
});

// ── Inline field edit (click to edit) ────────────────────────────────────────
function bindInlineEdit(el: HTMLElement) {
  el.addEventListener('click', () => {
    const field    = el.dataset.field!;
    const endpoint = el.dataset.endpoint!;
    const cur      = parseFloat(el.textContent!.replace(/[$,]/g,'')) || 0;
    const inp      = document.createElement('input');
    inp.type = 'number'; inp.step = '0.01'; inp.value = String(cur);
    inp.className = 'w-28 rounded border border-brand-green bg-white px-2 py-0.5 text-sm tabular-nums focus:outline-none';
    el.replaceWith(inp); inp.focus(); inp.select();
    async function save() {
      const v = parseFloat(inp.value);
      el.textContent = isNaN(v) ? usd(cur) : usd(v);
      inp.replaceWith(el);
      if (!isNaN(v)) { 
        await api(endpoint,'POST',{month:MONTH,[field]:v}).catch(()=>{}); 
        recomputeCC(); 
         
      }
    }
    inp.addEventListener('blur', save);
    inp.addEventListener('keydown', e => { if(e.key==='Enter') save(); if(e.key==='Escape'){el.textContent=usd(cur);inp.replaceWith(el);} });
  });
}
document.querySelectorAll<HTMLElement>('.editable-field').forEach(bindInlineEdit);

// ── Savings allocation edit ─────────────────────────────────────────────────
// When user changes "Transfer to savings", update savings_after on backend
// and recompute both end balances in the DOM
document.querySelectorAll<HTMLElement>('.savings-allocation-edit').forEach(el => {
  el.addEventListener('click', () => {
    const savingsStart = parseFloat(el.dataset.savingsStart ?? '0');
    const cur = parseFloat(el.textContent!.replace(/[$,]/g,'')) || 0;
    const inp = document.createElement('input');
    inp.type = 'number'; inp.step = '0.01'; inp.value = String(cur);
    inp.className = 'w-28 rounded border border-brand-green bg-white px-2 py-0.5 text-sm tabular-nums focus:outline-none';
    el.replaceWith(inp); inp.focus(); inp.select();
    async function save() {
      const v = parseFloat(inp.value) || 0;
      el.textContent = usd(v);
      inp.replaceWith(el);
      // Save savings_after = savings_start + allocation
      const newSavingsAfter = savingsStart + v;
      await api('/api/budget/summary', 'POST', { month: MONTH, savings_after: newSavingsAfter }).catch(() => {});
      // Update DOM: savings end
      const savEndEl = document.getElementById('savings-end-val');
      if (savEndEl) savEndEl.textContent = usd(newSavingsAfter);
      // Update DOM: checking end = checking_start + NET - savings_allocation
      const checkStart = parseFloat(document.querySelector('[data-field="checking_before"]')?.textContent?.replace(/[$,]/g,'') ?? '0');
      // Parse NET from the NET display
      const netEl = document.querySelector('[data-net-amount]') as HTMLElement;
      const netVal = netEl ? parseFloat(netEl.dataset.netAmount ?? '0') : 0;
      const newCheckEnd = checkStart + netVal - v;
      const checkEndEl = document.getElementById('checking-end-val');
      if (checkEndEl) { checkEndEl.textContent = usd(newCheckEnd); checkEndEl.className = checkEndEl.className.replace(/text-brand-\w+|text-stone-800/g, '') + (newCheckEnd >= 0 ? ' text-stone-800' : ' text-brand-red'); }
      // Also save checking_after
      await api('/api/budget/summary', 'POST', { month: MONTH, checking_after: newCheckEnd }).catch(() => {});
      // Update deduction display
      const deductEl = document.getElementById('checking-savings-deduct');
      if (deductEl) deductEl.textContent = '-' + usd(v);
    }
    inp.addEventListener('blur', save);
    inp.addEventListener('keydown', e => { if (e.key === 'Enter') save(); if (e.key === 'Escape') { el.textContent = usd(cur); inp.replaceWith(el); } });
  });
});

