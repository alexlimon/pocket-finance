    el.replaceWith(inp); inp.focus(); if(isAmt) inp.select();
    async function save() {
      const v = isAmt ? parseFloat(inp.value) : inp.value.trim();
      el.textContent = isAmt ? usd(Number(v)) : String(v);
      inp.replaceWith(el);
      if(v || v===0) { await api('/api/budget/cc-charge','PATCH',{id,[isAmt?'amount':'description']:v}).catch(()=>{}); if(isAmt) recomputeCC(); }
    }
    inp.addEventListener('blur',save);
    inp.addEventListener('keydown', e => { if(e.key==='Enter')save(); if(e.key==='Escape')inp.replaceWith(el); });
