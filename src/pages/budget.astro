document.querySelectorAll<HTMLFormElement>('.add-cash-form').forEach(form => {
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const d    = new FormData(form);
    const type = String(d.get('type')||'expense');
    const date = String(d.get('date')||'').trim()||null;
    const desc = String(d.get('description')||'').trim();
    const entity_id = String(d.get('entity_id')||'household');
    const amt  = parseFloat(String(d.get('amount')));
    if (!desc||isNaN(amt)) return;
    try {
      const res = await api('/api/budget/cash-expense','POST',{month:MONTH,date,description:desc,amount:amt,type,entity_id}) as {id:string};
      const list=document.getElementById('cash-expenses-list')!;
      const empty=list.querySelector('p'); if(empty) empty.remove();
      const isIncome = type==='income';
      const row=document.createElement('div'); row.dataset.cashId=res.id;
      row.className='flex items-center gap-2 text-sm group rounded-lg px-2 py-1.5 hover:bg-surface-hover';
      row.innerHTML=`
        <span class="rounded px-1.5 py-0.5 text-xs flex-shrink-0 border ${isIncome?'border-lime-300 text-brand-green bg-lime-50':'border-surface-border text-stone-400'}">${type}</span>
        <span class="text-stone-400 text-xs w-20 flex-shrink-0">${date??'—'}</span>
        <span class="flex-1 text-stone-700 truncate">${desc}</span>
        ${entity_id!=='household'?`<span class="rounded border border-surface-border px-1.5 py-0.5 text-xs capitalize text-stone-400 flex-shrink-0">${entity_id}</span>`:''}
        <span class="tabular-nums flex-shrink-0 font-medium ${isIncome?'text-brand-green':'text-stone-700'}">${isIncome?'+':''}${usd(amt)}</span>
        <button class="delete-cash opacity-0 group-hover:opacity-100 text-stone-400 hover:text-brand-red text-xs px-1" data-id="${res.id}">✕</button>
      `;
      list.appendChild(row);
      row.querySelector('.delete-cash')?.addEventListener('click',async()=>{await fetch(`/api/budget/cash-expense?id=${res.id}`,{method:'DELETE'});row.remove();});
      form.reset();
      
    } catch(err){alert(String(err));}
  });
});

// Save computed checking_end to DB on page load so next month can use it as checking_before
(function() {
  const checkEndEl = document.getElementById('checking-end-val');
  if (checkEndEl) {
    const checkEnd = parseFloat(checkEndEl.textContent!.replace(/[$,]/g,'') ?? '0');
    if (!isNaN(checkEnd)) {
      api('/api/budget/summary', 'POST', { month: MONTH, checking_after: checkEnd }).catch(() => {});
    }
  }
})();
