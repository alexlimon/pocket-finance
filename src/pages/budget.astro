// ── Fetch billing settings (needed for big purchase payment-month labels) ─────
let billingSettings: Record<string, {billing_end_day:number; payment_day:number; display_name:string}> = {};
fetch('/api/budget/cc-settings').then(r=>r.json()).then((d:any) => {
  for (const s of (d.settings ?? [])) billingSettings[s.card] = s;
});

function payMonthFor(date: string, card: string): {pm:string; pmFmt:string} {
  if (!date || !billingSettings[card]) return {pm:'unknown', pmFmt:'No Date Set'};
  const [yr,mo,dy] = date.split('-').map(Number);
  const endDay = billingSettings[card].billing_end_day;
  const payDay = billingSettings[card].payment_day;
  const d = dy <= endDay ? new Date(yr, mo, 1) : new Date(yr, mo+1, 1);
  const pm = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
  const pmFmt = `Paying in ${d.toLocaleString('en-US',{month:'long',year:'numeric'})} (due ${payDay}th)`;
  return {pm, pmFmt};
}

// ── Add big purchase ──────────────────────────────────────────────────────────
const addBigForm = document.getElementById('add-big-form') as HTMLFormElement;
addBigForm?.addEventListener('submit', async e => {
  e.preventDefault();
  const data = new FormData(addBigForm);
  const date=String(data.get('date')??'').trim(), card=String(data.get('card')),
        desc=String(data.get('description')??'').trim(), amount=parseFloat(String(data.get('amount')));
  if (!date||!desc||isNaN(amount)) return;
  try {
    const res = await api('/api/budget/cc-charge','POST',{month:MONTH,date,card,description:desc,amount,is_big_purchase:true}) as {id:string;payment_month:string|null};
    const pm = res.payment_month ?? 'unknown';
    const {pmFmt} = payMonthFor(date, card);
    const container = document.getElementById('big-cc-charges')!;
    const empty = container.querySelector('p'); if (empty) empty.remove();

    let groupEl = container.querySelector(`[data-big-pay-month="${pm}"]`) as HTMLElement | null;
    if (!groupEl) {
      groupEl = document.createElement('div');
      groupEl.setAttribute('data-big-pay-month', pm);
      groupEl.className = 'rounded-lg border border-surface-border overflow-hidden';
      groupEl.innerHTML = `
        <div class="flex items-center justify-between bg-surface px-3 py-2">
          <span class="text-xs font-semibold text-stone-600">${pmFmt}</span>
          <span class="big-group-total tabular-nums text-xs font-medium text-stone-600">${usd(0)}</span>
        </div>
        <div class="big-charges-body divide-y divide-surface-border"></div>
      `;
      container.appendChild(groupEl);
    }
    const cardOptions = Object.entries(billingSettings).map(([c,s])=>`<option value="${c}"${c===card?' selected':''}>${(s as any).display_name}</option>`).join('');
    const row = document.createElement('div');
    row.dataset.ccId = res.id;
    row.className = 'flex items-center gap-2 px-3 py-2 hover:bg-surface-hover group text-sm';
    row.innerHTML = `
      <span class="text-stone-400 text-xs w-20 flex-shrink-0 tabular-nums">${date}</span>
      <select class="cc-card-select rounded border border-surface-border bg-surface px-1.5 py-0.5 text-xs text-stone-500 flex-shrink-0" data-id="${res.id}">${cardOptions}</select>
      <span class="editable-cc-desc flex-1 cursor-pointer rounded px-1 hover:bg-surface-hover text-stone-700 truncate" data-id="${res.id}">${desc}</span>
      <span class="editable-cc-amount tabular-nums cursor-pointer rounded px-1.5 hover:bg-surface-hover text-stone-700 flex-shrink-0" data-id="${res.id}">${usd(amount)}</span>
      <button class="delete-cc-charge opacity-0 group-hover:opacity-100 text-stone-400 hover:text-brand-red text-xs px-1" data-id="${res.id}">✕</button>
    `;
    groupEl.querySelector('.big-charges-body')!.appendChild(row);
    const tot = groupEl.querySelector('.big-group-total');
    if (tot) { const c=parseFloat(tot.textContent!.replace(/[$,]/g,''))||0; tot.textContent=usd(c+amount); }
    row.querySelector('.delete-cc-charge')?.addEventListener('click', async () => {
      await fetch(`/api/budget/cc-charge?id=${res.id}`,{method:'DELETE'});
      row.remove();
      if (!groupEl!.querySelectorAll('[data-cc-id]').length) groupEl!.remove();
      recomputeCC();
    });
    addBigForm.reset(); recomputeCC();
  } catch(err){alert(String(err));}
});

