---
import Layout from '../layouts/Layout.astro';
import { verifySession } from '../lib/auth';
import { getClient } from '../lib/db';
import { getGmailStatus } from '../lib/gmail';
import CSVAnalyzer from '../components/CSVAnalyzer';

const env = Astro.locals.runtime.env;
if (!(await verifySession(Astro.request, env))) return Astro.redirect('/login');

const client = getClient(env);
let initialTransactions = '[]';

try {
  const result = await client.execute(
    `SELECT id, account_last4, account_source, date, post_date,
            description, category, type, amount, memo, uploaded_at
     FROM csv_transactions
     ORDER BY date DESC`
  );
  initialTransactions = JSON.stringify(result.rows);
} catch {
  // Table not yet created — run npm run migrate:csv
} finally {
  client.close();
}

const gmailStatus = await getGmailStatus(env);
const initialGmailStatus = JSON.stringify(gmailStatus);
---

<Layout title="Analyze" wide={true}>
  <CSVAnalyzer
    initialTransactions={initialTransactions}
    initialGmailStatus={initialGmailStatus}
    client:load
  />
</Layout>
