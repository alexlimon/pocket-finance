---
interface Props {
  title?:       string;
  description?: string;
  showNav?:     boolean;
  wide?:        boolean;
}

const {
  title       = 'LimeTiramisu',
  description = 'Your household financial planner.',
  showNav     = true,
  wide        = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="theme-color" content="#f0f1e8" />
    <meta name="color-scheme" content="light" />
    <meta name="darkreader-lock" />
    <title>{title} — LimeTiramisu</title>

    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=inter:300,400,500,600,700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root { color-scheme: only light; }

      /* Force light palette even if OS/browser requests dark */
      @media (prefers-color-scheme: dark) {
        :root { color-scheme: light; }
        html  { background-color: #f0f1e8 !important; color: #1c1917 !important; }
        body  { background-color: #f0f1e8 !important; }
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body { font-family: 'Inter', system-ui, sans-serif; }
      .tabular-nums { font-variant-numeric: tabular-nums; }
      button, a { transition: opacity 0.15s, color 0.15s, background-color 0.15s; }

      /* Mobile: bottom nav spacing */
      @supports (padding-bottom: env(safe-area-inset-bottom)) {
        .mobile-nav { padding-bottom: env(safe-area-inset-bottom); }
      }

      /* Checkbox accent for light theme */
      input[type="checkbox"] { accent-color: #65a30d; }
    </style>
  </head>

  <body class="h-full bg-surface text-stone-800 antialiased">
    {showNav && (
      <>
        {/* Desktop nav */}
        <header class="sticky top-0 z-50 border-b border-surface-border bg-surface/95 backdrop-blur hidden sm:block">
          <nav class={`mx-auto flex items-center justify-between px-4 py-3 ${wide ? 'max-w-7xl' : 'max-w-2xl'}`}>
            <a href="/" class="flex items-center gap-2 text-sm font-bold tracking-tight text-stone-800 hover:opacity-80">
              <!-- Tiramisu slice icon: cocoa top / cream / espresso ladyfinger / lime zest dot -->
              <svg width="22" height="20" viewBox="0 0 22 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <!-- ladyfinger / espresso base -->
                <rect x="1" y="13" width="20" height="6" rx="2" fill="#92400e"/>
                <!-- cream layer -->
                <rect x="1" y="6" width="20" height="7" fill="#fef3e2"/>
                <!-- cocoa-dusted top -->
                <rect x="1" y="1" width="20" height="5" rx="1.5" fill="#6b3a1f"/>
                <!-- lime zest accent -->
                <circle cx="17" cy="3.5" r="2" fill="#65a30d"/>
                <circle cx="17" cy="3.5" r="1" fill="#84cc16"/>
              </svg>
              LimeTiramisu
            </a>

            <div class="flex items-center gap-1">
              <a href="/budget"
                class="rounded-lg px-3 py-1.5 text-sm text-stone-500 hover:bg-surface-hover hover:text-stone-800"
              >Budget</a>
              <a href="/budget/year"
                class="rounded-lg px-3 py-1.5 text-sm text-stone-500 hover:bg-surface-hover hover:text-stone-800"
              >Year</a>
              <a href="/budget/recurring"
                class="rounded-lg px-3 py-1.5 text-sm text-stone-500 hover:bg-surface-hover hover:text-stone-800"
              >Recurring</a>
              <a href="/"
                class="rounded-lg px-3 py-1.5 text-sm text-stone-500 hover:bg-surface-hover hover:text-stone-800"
              >Dashboard</a>
              <a href="/connect"
                class="rounded-lg px-3 py-1.5 text-sm text-stone-500 hover:bg-surface-hover hover:text-stone-800"
              >Accounts</a>
              <form action="/api/auth/logout" method="POST" class="ml-2">
                <button type="submit"
                  class="rounded-lg border border-surface-border px-3 py-1.5 text-xs text-stone-400 hover:border-stone-400 hover:text-stone-600"
                >Sign out</button>
              </form>
            </div>
          </nav>
        </header>

        {/* Mobile bottom tab bar */}
        <nav class="mobile-nav fixed bottom-0 left-0 right-0 z-50 border-t border-surface-border bg-surface-card/95 backdrop-blur sm:hidden">
          <div class="flex items-center justify-around px-2 py-2">
            <a href="/budget" class="flex flex-col items-center gap-0.5 px-2 py-1 text-stone-500 hover:text-brand-green">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 7h6m-6 4h6m-6 4h4M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/></svg>
              <span class="text-[10px] font-medium">Budget</span>
            </a>
            <a href="/budget/year" class="flex flex-col items-center gap-0.5 px-2 py-1 text-stone-500 hover:text-brand-green">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <span class="text-[10px] font-medium">Year</span>
            </a>
            <a href="/" class="flex flex-col items-center gap-0.5 px-2 py-1 text-stone-500 hover:text-brand-green">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
              <span class="text-[10px] font-medium">Home</span>
            </a>
            <a href="/connect" class="flex flex-col items-center gap-0.5 px-2 py-1 text-stone-500 hover:text-brand-green">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              <span class="text-[10px] font-medium">Accounts</span>
            </a>
            <form action="/api/auth/logout" method="POST" class="flex flex-col items-center gap-0.5">
              <button type="submit" class="flex flex-col items-center gap-0.5 px-2 py-1 text-stone-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                <span class="text-[10px] font-medium">Out</span>
              </button>
            </form>
          </div>
        </nav>
      </>
    )}

    <main class={`mx-auto px-4 py-5 pb-24 sm:pb-6 ${wide ? 'max-w-7xl' : 'max-w-2xl'}`}>
      <slot />
    </main>
  </body>
</html>
